# OKX DEX Limit Order Service Configuration
NODE_ENV=development

# Infrastructure
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security & Signing
TEE_ENDPOINT=
DEV_SECRET=ReplaceWithAtLeast32CharSecretForDev

# Data Sources
OKX_WS_URL=wss://wspap.okx.com/ws/v5/public
BINANCE_REST_URL=https://api.binance.com
CHAINLINK_RPCS={"ethereum": "https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY"}

# Engine Tuning
MAX_ACTIVE_INTENTS_PER_USER=100
PRICE_CACHE_TTL_MS=30000
TRIGGER_DEBOUNCE_MS=30000
STALE_THRESHOLD_MS=300000
EXECUTION_RETRY_MAX=3
GAS_COST_MAX_RATIO=0.5
MIN_TRIGGER_DELTA_BPS=1000
MIN_OCO_STOP_DELTA_BPS=100
