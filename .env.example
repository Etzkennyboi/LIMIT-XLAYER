# SKILL_MODE: simulation | mcp | live
# simulation = local dev with fake responses
# mcp        = Antigravity MCP runtime (hackathon judging)
# live       = direct RPC (advanced, requires private key fallback)
SKILL_MODE=simulation

# MCP Endpoint overrides (set by Antigravity runtime automatically)
UNISWAP_POOL_DATA_ENDPOINT=mcp://uniswap-pool-data
UNISWAP_QUOTE_ENDPOINT=mcp://uniswap-quote
UNISWAP_SWAP_ENDPOINT=mcp://uniswap-swap
OKX_WALLET_ENDPOINT=mcp://okx-agentic-wallet

# Dev-only fallback (NEVER use in production)
# DEV_PRIVATE_KEY=0x...
